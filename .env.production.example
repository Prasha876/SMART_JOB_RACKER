# Production Environment Configuration Template
# Copy this file to .env for production deployment

# Server Configuration
PORT=5000
NODE_ENV=production

# Database Configuration
# Use MongoDB Atlas or your production MongoDB instance
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/smart-job-tracker?retryWrites=true&w=majority

# JWT Configuration
# IMPORTANT: Generate a secure secret using: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=CHANGE_THIS_TO_A_SECURE_RANDOM_STRING_IN_PRODUCTION
JWT_EXPIRE=30d

# CORS Configuration
# Set this to your production frontend URL
CORS_ORIGIN=https://your-production-domain.com
